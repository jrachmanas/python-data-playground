# Copy to `.env` (which is gitignored) and fill with your real values.
# Used by the smoke-test curls in RUNBOOK_SLM.md, and handed to the client app (see
# INTEGRATION_HANDOFF.md). Connection is the native RunPod OpenAI route — no local shim.

# RunPod API key — Settings -> API Keys -> Create (Restricted: inference Read/Write,
# GraphQL None). Secret. Never commit.
RUNPOD_API_KEY=

# The serverless endpoint id — shown on the endpoint page after you deploy it (Step 3).
# Not a credential on its own, but keep it out of git per repo convention.
RUNPOD_ENDPOINT_ID=

# Model tag served by the worker's Ollama. Must match what the client app requests.
SLM_MODEL=qwen3:4b-instruct
